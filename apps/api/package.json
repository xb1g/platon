{
  "name": "@memory/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "register:nevermined": "tsx src/scripts/register-nevermined-agent.ts",
    "verify:nevermined": "tsx src/scripts/verify-nevermined-smoke.ts",
    "test": "vitest run",
    "test:e2e:smoke": "RUN_LIVE_E2E_SMOKE=1 vitest run -- tests/e2e/session-retrieval.e2e.test.ts",
    "smoke:e2e": "tsx src/scripts/run-e2e-smoke.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/src/server.js"
  },
  "devDependencies": {
    "@types/pg": "^8.15.5"
  },
  "dependencies": {
    "@memory/shared": "workspace:*",
    "@nevermined-io/payments": "1.1.6",
    "@fastify/cors": "^10.0.1",
    "bullmq": "^5.34.10",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.2",
    "neo4j-driver": "^5.27.0",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  }
}
